# Copy this file to backend/.env.local for local secrets.
GMI_API_BASE=https://api.gmi-serving.com/v1
GMI_API_KEY=
GMI_MODEL=anthropic/claude-sonnet-4.5
GMI_TIMEOUT_SECONDS=40

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=DragonWay Lab

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/gmail/callback
GOOGLE_FRONTEND_SUCCESS_URL=http://localhost:8080
